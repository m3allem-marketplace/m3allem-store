{
  "buildCommand": "npm run build",
  "outputDirectory": "dist/m3allem-ecommerce/browser",
  "cleanUrls": true,
  "trailingSlash": false,
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://m3allem-store-dashboard.vercel.app/api/:path*"
    },
    {
      "source": "/:path*",
      "destination": "/index.html"
    }
  ]
}
